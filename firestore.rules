rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function signedIn() {
      return request.auth != null;
    }

    function getUsername() {
      return request.auth.token.email.split('@')[0] == 'cof.techbook' ? 'cof@techbook' : request.auth.token.email.split('@')[0];
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(getUsername()));
    }

    function isOwner(studentId) {
      return signedIn() && request.auth.token.email.lower() == studentId.lower() + '@techbook.ac.in';
    }

    match /students/{studentId} {
      allow read, write: if isAdmin() || isOwner(studentId);
      allow create: if signedIn() && !exists(/databases/$(database)/documents/admins/$(studentId.lower())) && request.auth.token.email.lower() == studentId.lower() + '@techbook.ac.in';
    }

    match /attendance/{attendanceId} {
      allow read, write: if isAdmin() || (signedIn() && resource.data.usn.lower() + '@techbook.ac.in' == request.auth.token.email.lower());
      allow create: if signedIn() && request.resource.data.usn.lower() + '@techbook.ac.in' == request.auth.token.email.lower();
    }

    match /attendance_codes/{codeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /password_reset_requests/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /quizzes/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /quiz_results/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.usn.lower() + '@techbook.ac.in' == request.auth.token.email.lower());
      allow create: if signedIn() && request.resource.data.usn.lower() + '@techbook.ac.in' == request.auth.token.email.lower();
      allow update, delete: if isAdmin();
    }

    match /techbook_notes/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /techbook_notes/{id}/chunks/{chunkId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /qbank_papers/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /qbank_papers/{id}/chunks/{chunkId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /pyq_papers/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /pyq_papers/{id}/chunks/{chunkId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /help_threads/{tid} {
      allow read, write: if isAdmin() || (signedIn() && tid.split('_')[0].lower() + '@techbook.ac.in' == request.auth.token.email.lower());
    }
    match /help_messages/{tid}/msgs/{msgId} {
      allow read, write: if isAdmin() || (signedIn() && tid.split('_')[0].lower() + '@techbook.ac.in' == request.auth.token.email.lower());
    }

    match /admins/{adminId} {
      allow read, write: if isAdmin() || (signedIn() && request.auth.token.email.lower() == adminId.lower() + '@techbook.ac.in');
    }

    match /admins_uids/{uid} {
      allow read, write: if isAdmin() || (signedIn() && request.auth.uid == uid);
    }

    match /promos/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /user_sessions/{sessionId} {
      allow read, write: if isAdmin();
    }

    match /user_activities/{activityId} {
      allow read: if isAdmin();
      allow write: if signedIn();
    }

    match /founder_messages/{id} {
      allow read, write: if isAdmin();
    }

    match /launches/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
