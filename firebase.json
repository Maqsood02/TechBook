{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase",
      ".git",
      ".gitignore",
      ".gemini",
      ".env",
      "node_modules",
      "server.js",
      "techbook-ai-worker.js",
      "test.js",
      "package.json",
      "package-lock.json",
      "TODO.md",
      "FIREBASE_RULES.txt",
      "sample_students.csv",
      "scratch",
      "**/*.log"
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  }
}